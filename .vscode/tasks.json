{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Game Logic",
      "type": "shell",
      "command": "javac",
      "args": [
        "-d",
        "bin",
        "-cp",
        "lib/junit-platform-console-standalone-1.10.2.jar",
        "TicTacToeGame.java",
        "TicTacToeGameTest.java"
      ],
      "group": "build",
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Run JUnit Tests",
      "type": "shell",
      "command": "java",
      "args": [
        "-jar",
        "lib/junit-platform-console-standalone-1.10.2.jar",
        "execute",
        "--class-path",
        "bin",
        "--scan-class-path"
      ],
      "dependsOn": "Build Game Logic",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
